NODE_ENV=development
PORT=4000
# Vite default is http://localhost:5173 — include all dev origins you use, comma-separated
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Prefer DATABASE_URL for hosted Postgres (e.g. Render). When set, DB_* below are ignored.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DB_SSL=false forces no SSL (useful for local DATABASE_URL). Omit or true for Render.

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=workshop_platform
DB_NAME_TEST=workshop_platform_test
DB_SSL=false

JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d

OTP_TTL_MINUTES=10

# Outlook.com: smtp-mail.outlook.com, 587, SMTP_SECURE=false, full email as SMTP_USER
# Microsoft 365 work/school: often smtp.office365.com with same settings
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@outlook.com
SMTP_PASS=your_password_or_app_password
MAIL_FROM="Your Name <you@outlook.com>"

RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
